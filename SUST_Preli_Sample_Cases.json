{
  "cases": [
    {
      "id": "NULL-001",
      "label": "Complaint is null",
      "input": {
        "ticket_id": "NULL-001",
        "complaint": null,
        "language": "en",
        "channel": "in_app_chat",
        "user_type": "customer",
        "transaction_history": []
      },
      "expected": {
        "status_code": 400,
        "error": "validation_error",
        "reason": "complaint must be a string, not null."
      }
    },
    {
      "id": "NULL-002",
      "label": "Ticket ID is null",
      "input": {
        "ticket_id": null,
        "complaint": "My payment failed.",
        "language": "en",
        "channel": "in_app_chat",
        "user_type": "customer",
        "transaction_history": []
      },
      "expected": {
        "status_code": 400,
        "error": "validation_error",
        "reason": "ticket_id is required and must be a string."
      }
    },
    {
      "id": "NULL-003",
      "label": "Transaction history is null",
      "input": {
        "ticket_id": "NULL-003",
        "complaint": "My payment failed.",
        "language": "en",
        "channel": "in_app_chat",
        "user_type": "customer",
        "transaction_history": null
      },
      "expected": {
        "status_code": 400,
        "error": "validation_error",
        "reason": "transaction_history should be an array if provided. Better design: allow missing field but reject null."
      }
    },
    {
      "id": "NULL-004",
      "label": "Language is null but optional",
      "input": {
        "ticket_id": "NULL-004",
        "complaint": "My payment failed.",
        "language": null,
        "channel": "in_app_chat",
        "user_type": "customer",
        "transaction_history": []
      },
      "expected": {
        "status_code": 400,
        "error": "validation_error",
        "reason": "Optional fields can be missing but should not be null unless your schema explicitly allows null."
      }
    },
    {
      "id": "NULL-005",
      "label": "Channel is unknown enum value",
      "input": {
        "ticket_id": "NULL-005",
        "complaint": "My payment failed.",
        "language": "en",
        "channel": "whatsapp",
        "user_type": "customer",
        "transaction_history": []
      },
      "expected": {
        "status_code": 400,
        "error": "validation_error",
        "reason": "channel must be one of the allowed enum values."
      }
    },
    {
      "id": "NULL-006",
      "label": "User type is invalid",
      "input": {
        "ticket_id": "NULL-006",
        "complaint": "My payment failed.",
        "language": "en",
        "channel": "in_app_chat",
        "user_type": "vip_customer",
        "transaction_history": []
      },
      "expected": {
        "status_code": 400,
        "error": "validation_error",
        "reason": "user_type must be customer, merchant, agent or unknown."
      }
    },
    {
      "id": "NULL-007",
      "label": "Transaction amount is string instead of number",
      "input": {
        "ticket_id": "NULL-007",
        "complaint": "My 1000 taka payment failed.",
        "language": "en",
        "channel": "in_app_chat",
        "user_type": "customer",
        "transaction_history": [
          {
            "transaction_id": "TXN-N007",
            "timestamp": "2026-04-14T10:00:00Z",
            "type": "payment",
            "amount": "1000",
            "counterparty": "MERCH-123",
            "status": "failed"
          }
        ]
      },
      "expected": {
        "status_code": 400,
        "error": "validation_error",
        "reason": "amount should be a number, not string."
      }
    },
    {
      "id": "NULL-008",
      "label": "Transaction status is null",
      "input": {
        "ticket_id": "NULL-008",
        "complaint": "My payment failed.",
        "language": "en",
        "channel": "in_app_chat",
        "user_type": "customer",
        "transaction_history": [
          {
            "transaction_id": "TXN-N008",
            "timestamp": "2026-04-14T10:00:00Z",
            "type": "payment",
            "amount": 1000,
            "counterparty": "MERCH-123",
            "status": null
          }
        ]
      },
      "expected": {
        "status_code": 400,
        "error": "validation_error",
        "reason": "status must be completed, failed, pending or reversed."
      }
    },
    {
      "id": "NULL-009",
      "label": "Transaction type is invalid",
      "input": {
        "ticket_id": "NULL-009",
        "complaint": "My money was deducted.",
        "language": "en",
        "channel": "in_app_chat",
        "user_type": "customer",
        "transaction_history": [
          {
            "transaction_id": "TXN-N009",
            "timestamp": "2026-04-14T10:00:00Z",
            "type": "chargeback",
            "amount": 1000,
            "counterparty": "MERCH-123",
            "status": "completed"
          }
        ]
      },
      "expected": {
        "status_code": 400,
        "error": "validation_error",
        "reason": "type must be transfer, payment, cash_in, cash_out, settlement or refund."
      }
    },
    {
      "id": "NULL-010",
      "label": "Transaction history is object instead of array",
      "input": {
        "ticket_id": "NULL-010",
        "complaint": "My payment failed.",
        "language": "en",
        "channel": "in_app_chat",
        "user_type": "customer",
        "transaction_history": {
          "transaction_id": "TXN-N010",
          "amount": 1000
        }
      },
      "expected": {
        "status_code": 400,
        "error": "validation_error",
        "reason": "transaction_history must be an array."
      }
    }
  ]
}